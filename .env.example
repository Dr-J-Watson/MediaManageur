# =============================================================================
# Paramètres généraux / General settings
# =============================================================================

# Domaine public utilisé pour les liens externes (reverse proxy, certificats TLS).
# Public domain used for external links (reverse proxy, TLS certificates).
# Exemple / Example : media.mondomaine.fr — ignoré si aucun reverse proxy n'est configuré / ignored if no reverse proxy is configured.
DOMAIN=example.local

# Adresse IP locale du serveur Docker, utilisée pour l'accès LAN aux interfaces web.
# Local IP address of the Docker host, used for LAN access to web interfaces.
# Doit correspondre à l'IP statique de la machine hôte / Must match the static IP of the host machine.
# Exemple / Example : 192.168.1.10
HOST_IP=192.168.1.10

# UID Linux appliqué aux fichiers créés par les conteneurs.
# Linux UID applied to files created by containers.
# Doit correspondre à l'utilisateur propriétaire de CONFIG_DIR et DATA_DIR.
# Must match the owner of CONFIG_DIR and DATA_DIR.
# Commande / Command : id -u $(whoami)
PUID=1000

# GID Linux associé à PUID, appliqué aux fichiers créés par les conteneurs.
# Linux GID associated with PUID, applied to files created by containers.
# Commande / Command : id -g $(whoami)
PGID=1000

# Fuseau horaire appliqué à l'ensemble des services.
# Timezone applied to all services.
# Format tz database : https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
# Exemple / Example : Europe/Paris, America/New_York, Asia/Tokyo
TZ=Europe/Paris


# =============================================================================
# Chemins de persistance / Persistence paths
# =============================================================================

# Répertoire racine des configurations de tous les services.
# Root directory for all service configurations.
# Chaque service y crée son propre sous-dossier au premier démarrage.
# Each service creates its own subdirectory on first start.
# Exemple / Example : /opt/appdata ou / or ./config
CONFIG_DIR=./config

# Répertoire racine des données (médias finalisés, torrents en cours, bibliothèques de jeux).
# Root directory for all data (finalized media, active torrents, game libraries).
# IMPORTANT : torrents/ et media/ doivent être sur le même volume pour que les hardlinks fonctionnent.
# IMPORTANT : torrents/ and media/ must be on the same volume for hardlinks to work.
# Structure attendue / Expected structure :
#   DATA_DIR/torrents/{movies,tv,music,games}
#   DATA_DIR/media/{films,series,musique,jeux}
DATA_DIR=./data


# =============================================================================
# Paramètres VPN (Gluetun) / VPN settings (Gluetun)
# =============================================================================

# Fournisseur VPN reconnu par Gluetun.
# VPN provider supported by Gluetun.
# Valeurs supportées / Supported values : mullvad, protonvpn, nordvpn, airvpn, custom, etc.
# Liste complète / Full list : https://github.com/qdm12/gluetun-wiki/tree/main/setup/providers
VPN_PROVIDER=custom

# Protocole du tunnel VPN.
# VPN tunnel protocol.
# Valeurs possibles / Possible values : wireguard, openvpn
# WireGuard est recommandé pour de meilleures performances / WireGuard is recommended for better performance.
VPN_TYPE=wireguard

# Clé privée WireGuard associée au compte VPN.
# WireGuard private key associated with the VPN account.
# Générée depuis l'espace client du fournisseur ou via / Generated from the provider dashboard or via : wg genkey
# Ne jamais commiter cette valeur dans un dépôt public / Never commit this value to a public repository.
VPN_KEY=your_wireguard_private_key_here

# Pays de sortie VPN préféré (nom en anglais).
# Preferred VPN exit country (English name).
# Certains fournisseurs acceptent aussi un code pays / Some providers also accept a country code : CH, NL, FR...
# Exemple / Example : Switzerland, Netherlands, France
VPN_COUNTRY=Switzerland


# =============================================================================
# Tags des images Docker / Docker image tags
# =============================================================================

# Définit la version de chaque image Docker utilisée par la stack.
# Defines the version of each Docker image used by the stack.
# "latest" récupère toujours la dernière version disponible au moment du pull.
# "latest" always pulls the most recent available version.
# En production, préférer un tag fixe (ex: v0.0.1) pour éviter les mises à jour non maîtrisées.
# In production, prefer a fixed tag (e.g. v0.0.1) to avoid uncontrolled updates.

GLUETUN_VERSION=latest
QBITTORRENT_VERSION=latest
PROWLARR_VERSION=latest
RADARR_VERSION=latest
SONARR_VERSION=latest
LIDARR_VERSION=latest
QUESTARR_VERSION=latest
JELLYSEERR_VERSION=latest
JELLYFIN_VERSION=latest
HOMARR_VERSION=latest
GAMEVAULT_VERSION=latest
FLARESOLVERR_VERSION=latest


# =============================================================================
# Base de données GameVault (PostgreSQL) / GameVault database (PostgreSQL)
# =============================================================================

# Mot de passe PostgreSQL partagé entre les services gamevault-db et gamevault.
# PostgreSQL password shared between the gamevault-db and gamevault services.
# Doit être défini avant le premier démarrage — toute modification ultérieure nécessite une réinitialisation manuelle de la base.
# Must be set before the first start — any later change requires a manual database reset.
# Ne jamais laisser la valeur par défaut en production / Never leave the default value in production.
GAMEVAULT_DB_PASSWORD=change_me_strong_password


# =============================================================================
# Ports externes exposés sur l'hôte / External ports exposed on the host
# =============================================================================

# Définit le port publié sur l'hôte pour accéder à chaque interface web.
# Defines the port published on the host to access each web interface.
# Le port interne (dans le conteneur) reste fixe — seul le port externe est configurable ici.
# The internal port (inside the container) is fixed — only the external port is configurable here.
# Modifier ces valeurs en cas de conflit avec un service existant sur l'hôte.
# Change these values if they conflict with an existing service on the host.
# Vérification des ports occupés / Check for used ports : ss -tlnp | grep <PORT>

# qBittorrent — WebUI accessible via Gluetun (port interne / internal port : 8080)
QBITTORRENT_PORT=38080

# Prowlarr — Gestionnaire d'indexers / Indexer manager (port interne / internal port : 9696)
PROWLARR_PORT=39696

# Radarr — Automatisation des films / Movie automation (port interne / internal port : 7878)
RADARR_PORT=37878

# Sonarr — Automatisation des séries / Series automation (port interne / internal port : 8989)
SONARR_PORT=38989

# Lidarr — Automatisation de la musique / Music automation (port interne / internal port : 8686)
LIDARR_PORT=38686

# Questarr — Acquisition de jeux vidéo / Video game acquisition (port interne / internal port : 5000)
QUESTARR_PORT=35000

# Jellyseerr — Interface de demandes médias / Media request interface (port interne / internal port : 5055)
JELLYSEERR_PORT=35055

# Jellyfin — Serveur de streaming / Streaming server (port interne / internal port : 8096)
JELLYFIN_PORT=38096

# Homarr — Tableau de bord central / Central dashboard (port interne / internal port : 7575)
HOMARR_PORT=37575

# GameVault — Bibliothèque de jeux / Game library (port interne / internal port : 8080)
GAMEVAULT_PORT=38081

# FlareSolverr — Bypass Cloudflare pour Prowlarr / Cloudflare bypass for Prowlarr (port interne / internal port : 8191)
FLARESOLVERR_PORT=38191